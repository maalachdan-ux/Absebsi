rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidStudent(data) {
      return data.nisn is string && data.nisn.size() <= 50 &&
             data.name is string && data.name.size() <= 150 &&
             data.class is string && data.class.size() <= 50 &&
             data.phone is string && data.phone.size() <= 50 &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 1048576)) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidAttendance(data) {
      return data.nisn is string && data.nisn.size() <= 50 &&
             data.name is string && data.name.size() <= 150 &&
             data.class is string && data.class.size() <= 50 &&
             data.timestamp is string && data.timestamp.size() <= 100 &&
             data.type is string && (data.type == 'Masuk' || data.type == 'Pulang') &&
             data.status is string && (data.status == 'Hadir' || data.status == 'Sakit' || data.status == 'Izin' || data.status == 'Alfa') &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 500)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 1048576));
    }

    match /students/{studentId} {
      allow read: if true;
      allow create, update: if isValidId(studentId) && isValidStudent(request.resource.data);
      allow delete: if isValidId(studentId);
    }

    match /attendance/{attendanceId} {
      allow read: if true;
      allow create, update: if isValidId(attendanceId) && isValidAttendance(request.resource.data);
      allow delete: if isValidId(attendanceId);
    }
  }
}
